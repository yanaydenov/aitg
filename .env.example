# Telegram API creds — получить на https://my.telegram.org
TG_API_ID=123456
TG_API_HASH=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TG_SESSION=aitg

# Telegram user id владельца (numeric). Глобальная память видна только ему.
OWNER_ID=0

# Отвечать в личных чатах (1=да, 0=нет)
ALLOW_PRIVATE=0

# Префикс команды
AI_PREFIX=.ai

# OpenRouter API key — https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Модель для чата (см. https://openrouter.ai/models)
MODEL=google/gemini-3.1-flash-lite-preview

# Модель для генерации изображений
IMAGE_MODEL=google/gemini-3.1-flash-image-preview

# Стиль общения бота (опционально)
STYLE_PROMPT=

# Таймаут агента в секундах
AGENT_TIMEOUT=120

# Сколько кадров вытаскивать из видео
VIDEO_FRAMES=12